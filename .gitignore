# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as long as your logic isn't
#  file-parameterized these can be ignored.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt


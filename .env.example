# Configuration COFINANCE CI
SECRET_KEY=remplacez-par-une-cle-secrete-aleatoire-longue-et-unique
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Laissez vide pour utiliser SQLite (par défaut en développement)
# Pour PostgreSQL, décommentez et configurez la ligne ci-dessous :
# DATABASE_URL=postgres://user:password@localhost:5432/cofinance_db
DATABASE_URL=

# CORS (origines autorisées séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Django Channels (WebSocket) — Redis requis en production multi-worker
# Laissez vide pour utiliser InMemoryChannelLayer (développement uniquement)
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# Configuration Stockage Cloud (Optionnel - AWS S3)
# Décommentez et renseignez pour utiliser un stockage de fichiers décentralisé en production
# AWS_ACCESS_KEY_ID=votre-access-key-id
# AWS_SECRET_ACCESS_KEY=votre-secret-access-key
# AWS_STORAGE_BUCKET_NAME=votre-nom-de-bucket-s3
# AWS_S3_REGION_NAME=eu-west-3
